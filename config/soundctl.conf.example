# Sound Control Configuration (Template)
# -----------------------------------------------------------

# Paths - Update these to match your installation directory
BASE_DIR="/path/to/your/smart-chime"
SOUNDS_DIR="${BASE_DIR}/sounds"
LOG_DIR="${BASE_DIR}/logs"
ROUTINE_SCHEDULE="${BASE_DIR}/config/schedule.txt"

# PLAYER (PipeWire native)
PLAYER="/usr/bin/pw-play"

# --- HOME ASSISTANT MANAGED SECTION ---
# These values can be toggled by external scripts
BELLS_ENABLED="on"
DEFAULT_VOLUME="0.8"
# --- END HA MANAGED SECTION ---
